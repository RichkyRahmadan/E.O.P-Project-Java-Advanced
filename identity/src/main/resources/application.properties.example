# =============================================================================
# E.O.P IDENTITY SERVICE — application.properties.example
# SALIN file ini menjadi application.properties dan isi nilainya.
# =============================================================================

server.port=8081
spring.application.name=eop-identity

# PostgreSQL — eop_identity_db
spring.datasource.url=jdbc:postgresql://localhost:5432/eop_identity_db
spring.datasource.username=postgres
spring.datasource.password=YOUR_POSTGRES_PASSWORD
spring.datasource.driver-class-name=org.postgresql.Driver

spring.jpa.hibernate.ddl-auto=validate
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect

# JWT Secret — WAJIB IDENTIK dengan gateway/application.yml
jwt.secret=Priestess_EOP_UAS_Secret_Key_2025_Secure!

logging.level.com.priestess.identity=DEBUG

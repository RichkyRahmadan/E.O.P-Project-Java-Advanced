# =============================================================================
# E.O.P GATEWAY — application.yml.example
# SALIN file ini menjadi application.yml dan isi nilainya.
# =============================================================================

server:
  port: 8080

spring:
  application:
    name: eop-gateway

# JWT Secret — WAJIB IDENTIK dengan identity/application.properties
jwt:
  secret: Priestess_EOP_UAS_Secret_Key_2025_Secure!

logging:
  level:
    com.priestess.gateway: DEBUG
    org.springframework.cloud.gateway: INFO
